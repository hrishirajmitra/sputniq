    ],
    "workflows": [
        {
            "id": "api-query-pipeline",
            "entrypoint_step": "start",
            "steps": [
                {
                    "id": "start",
                    "type": "agent",
                    "ref": "api-assistant",
                    "next": []
                }
            ]
        }
    ]
