            "GOOGLE_API_KEY": "AIzaSyA9gdhkLx3187dIF2sovdpCUzzhyBgj_NI"
        }
    },
    "models": [
        {
            "id": "gemini-2.5-flash",
            "provider": "google"
        }
    ],
    "tools": [
        {
            "id": "custom-api-fetch",
            "entrypoint": "src/tools/api_fetch.py:fetch_api_data",
            "schema": {
                "input": {"endpoint": {"type": "string"}, "params": {"type": "object"}},
                "output": {"response": {"type": "object"}}
            }
        }
